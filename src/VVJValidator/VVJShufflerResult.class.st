Class {
	#name : 'VVJShufflerResult',
	#superclass : 'Object',
	#instVars : [
		'shuffler'
	],
	#category : 'VVJValidator',
	#package : 'VVJValidator'
}

{ #category : 'accessing' }
VVJShufflerResult >> shuffler [

	^ shuffler
]

{ #category : 'accessing' }
VVJShufflerResult >> shuffler: anObject [

	shuffler := anObject
]
